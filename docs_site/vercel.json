{
  "version": 2,
  "cleanUrls": true,
  "framework": null,
  "public": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/onboard",
      "destination": "/index.html#onboarding"
    },
    {
      "source": "/setup",
      "destination": "/index.html#installation"
    }
  ]
}
